-- ============================================================
-- DML: SELECTS - CONSULTAS DE VALIDACAO
-- ============================================================

-- ===== Usuario =====
SELECT * FROM Usuario;
SELECT COUNT(*) AS total_usuarios FROM Usuario;
SELECT nome, NUMCEP FROM Usuario WHERE NUMCEP LIKE '70%';
SELECT nome, email FROM Usuario ORDER BY nome ASC;

-- ===== Vendedor =====
SELECT * FROM Vendedor;
SELECT nome, cidade, avaliacao FROM Vendedor WHERE avaliacao > 4.7 ORDER BY avaliacao DESC;
SELECT COUNT(*) AS total_produtores FROM Vendedor;
SELECT nome, descricao FROM Vendedor WHERE cidade LIKE '%DF%';
SELECT nome, avaliacao FROM Vendedor ORDER BY avaliacao DESC LIMIT 1;

-- ===== Categoria =====
SELECT * FROM Categoria;
SELECT * FROM Categoria WHERE nome = 'Conservas em lata';
SELECT COUNT(*) AS total_categorias FROM Categoria;
SELECT nome FROM Categoria ORDER BY nome ASC;
SELECT nome, descricao FROM Categoria WHERE id_categoria = 1;

-- ===== Produto =====
SELECT nome, preco, badge FROM Produto WHERE ativo = 1;
SELECT nome, preco_antigo, preco FROM Produto WHERE preco_antigo IS NOT NULL;
SELECT nome, preco FROM Produto WHERE badge = 'Mais Vendido';
SELECT p.nome AS produto, c.nome AS categoria, p.preco
FROM Produto p JOIN Categoria c ON p.id_categoria = c.id_categoria
ORDER BY c.nome;
SELECT nome, preco FROM Produto WHERE ativo = 1 ORDER BY preco ASC;

-- ===== Pedido =====
SELECT codigo_rastreio, status, valor_total, dt_pedido FROM Pedido;
SELECT codigo_rastreio, valor_total, status FROM Pedido WHERE id_usuario = 1;
SELECT SUM(valor_total) AS receita_entregues FROM Pedido WHERE status = 'entregue';
SELECT status, COUNT(*) AS quantidade FROM Pedido GROUP BY status;
SELECT codigo_rastreio, dt_pedido FROM Pedido ORDER BY dt_pedido DESC LIMIT 1;

-- ===== Item_Pedido =====
SELECT * FROM Item_Pedido;
SELECT ip.id_pedido, p.nome AS produto, ip.quantidade, ip.preco_unitario_registrado
FROM Item_Pedido ip JOIN Produto p ON ip.id_produto = p.id_produto
WHERE ip.id_pedido = 2;


-- ===== Pagamento =====

-- 1. Todos os pagamentos
SELECT * FROM Pagamento;

-- 2. Resumo completo: cliente, pedido, metodo, status e valor
SELECT u.nome AS cliente, pe.codigo_rastreio, pa.metodo, pa.valor_pago
FROM Pagamento pa
JOIN Pedido  pe ON pa.id_pedido  = pe.id_pedido
JOIN Usuario u  ON pe.id_usuario = u.id_usuario
LIMIT 0, 1000;

-- 3. Total arrecadado com pagamentos aprovados
SELECT SUM(valor_pago) AS total_aprovado
FROM Pagamento WHERE status = 'aprovado';

-- 4. Quantidade de pagamentos por metodo
SELECT metodo, COUNT(*) AS quantidade
FROM Pagamento
GROUP BY metodo ORDER BY quantidade DESC;

-- 5. Pagamentos pendentes
SELECT u.nome AS cliente, pe.codigo_rastreio, pa.metodo, pa.valor_pago
FROM Pagamento pa
JOIN Pedido  pe ON pa.id_pedido  = pe.id_pedido
JOIN Usuario u  ON pe.id_usuario = u.id_usuario
