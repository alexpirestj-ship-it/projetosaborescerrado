-- SABORES DO CERRADO
-- Marketplace Regional de Produtos Artesanais do DF
-- Disciplina: Banco de dados


DROP DATABASE IF EXISTS db_sabores_cerrado;
CREATE DATABASE db_sabores_cerrado;
USE db_sabores_cerrado;

CREATE TABLE ESTADO (
    CODUF  CHAR(2)      NOT NULL,
    DESCUF VARCHAR(50)  NOT NULL,
    PRIMARY KEY (CODUF)
);

CREATE TABLE CIDADE (
    IDCIDADE   SMALLINT     NOT NULL,
    CODUF      CHAR(2)      NOT NULL,
    NOMECIDADE VARCHAR(100) NOT NULL,
    PRIMARY KEY (IDCIDADE),
    CONSTRAINT FK_ESTADO_CIDADE FOREIGN KEY (CODUF) REFERENCES ESTADO (CODUF)
);

CREATE TABLE BAIRRO (
    IDBAIRRO   INT          NOT NULL,
    IDCIDADE   SMALLINT     NOT NULL,
    DESCBAIRRO VARCHAR(100) NOT NULL,
    PRIMARY KEY (IDBAIRRO),
    CONSTRAINT FK_CIDADE_BAIRRO FOREIGN KEY (IDCIDADE) REFERENCES CIDADE (IDCIDADE)
);

CREATE TABLE LOGRADOURO (
    NUMCEP         CHAR(8)      NOT NULL,
    IDBAIRRO       INT          NOT NULL,
    DESCLOGRADOURO VARCHAR(200) NOT NULL,
    PRIMARY KEY (NUMCEP),
    CONSTRAINT FK_BAIRRO_LOGRADOURO FOREIGN KEY (IDBAIRRO) REFERENCES BAIRRO (IDBAIRRO)
);

-- ============================================================
-- DDL: TABELAS PRINCIPAIS
-- ============================================================
CREATE TABLE Usuario (
  id_usuario       INT          NOT NULL AUTO_INCREMENT COMMENT 'Identificador unico do usuario',
  nome             VARCHAR(100) NOT NULL                COMMENT 'Nome completo do cliente',
  email            VARCHAR(150) NOT NULL                COMMENT 'E-mail de acesso e contato',
  senha_hash       VARCHAR(100) NOT NULL                COMMENT 'Hash bcrypt da senha',
  NUMCEP           CHAR(8)      NOT NULL,
  dt_cadastro      DATETIME     NOT NULL DEFAULT NOW()  COMMENT 'Data e hora do cadastro',
  NUMENDERECO      VARCHAR(10)  NOT NULL,
  DESC_COMPLEMENTO VARCHAR(100),
  PRIMARY KEY (id_usuario),
  UNIQUE KEY uk_usuario_email (email),
  CONSTRAINT FK_LOGRADOURO_Usuario FOREIGN KEY (NUMCEP) REFERENCES LOGRADOURO (NUMCEP)
) COMMENT = 'Cadastro de clientes da plataforma';

CREATE TABLE Vendedor (
  id_vendedor INT           NOT NULL AUTO_INCREMENT COMMENT 'Identificador unico do vendedor',
  nome        VARCHAR(100)  NOT NULL                COMMENT 'Nome ou razao social do produtor',
  cidade      VARCHAR(80)   NOT NULL                COMMENT 'Cidade de origem do produtor',
  avaliacao   DECIMAL(2,1)  NOT NULL DEFAULT 0.0    COMMENT 'Nota media entre 0.0 e 5.0',
  descricao   TEXT          NULL                    COMMENT 'Apresentacao do produtor',
  PRIMARY KEY (id_vendedor)
) COMMENT = 'Produtores regionais parceiros do marketplace';

CREATE TABLE Categoria (
  id_categoria INT          NOT NULL AUTO_INCREMENT COMMENT 'Identificador unico da categoria',
  nome         VARCHAR(50)  NOT NULL                COMMENT 'Nome da categoria',
  descricao    VARCHAR(200) NULL                    COMMENT 'Descricao opcional',
  PRIMARY KEY (id_categoria),
  UNIQUE KEY uk_categoria_nome (nome)
) COMMENT = 'Categorias de produtos do catalogo';

CREATE TABLE Produto (
  id_produto   INT           NOT NULL AUTO_INCREMENT COMMENT 'Identificador unico do produto',
  id_vendedor  INT           NOT NULL                COMMENT 'FK - produtor responsavel',
  id_categoria INT           NOT NULL                COMMENT 'FK - categoria do produto',
  nome         VARCHAR(100)  NOT NULL                COMMENT 'Nome comercial do produto',
  descricao    TEXT          NULL                    COMMENT 'Descricao detalhada',
  preco        DECIMAL(10,2) NOT NULL                COMMENT 'Preco de venda atual',
  preco_antigo DECIMAL(10,2) NULL                    COMMENT 'Preco anterior em promocoes',
  badge        VARCHAR(30)   NULL                    COMMENT 'Badge: Novo, Promocao, Mais Vendido',
  ativo        TINYINT(1)    NOT NULL DEFAULT 1      COMMENT '1=disponivel 0=inativo',
  PRIMARY KEY (id_produto),
  CONSTRAINT fk_produto_vendedor  FOREIGN KEY (id_vendedor)  REFERENCES Vendedor  (id_vendedor),
  CONSTRAINT fk_produto_categoria FOREIGN KEY (id_categoria) REFERENCES Categoria (id_categoria)
) COMMENT = 'Catalogo de produtos artesanais do cerrado';

CREATE TABLE Pedido (
  id_pedido       INT                                      NOT NULL AUTO_INCREMENT COMMENT 'Identificador unico do pedido',
  id_usuario      INT                                      NOT NULL                COMMENT 'FK - usuario que realizou o pedido',
  codigo_rastreio VARCHAR(20)                              NOT NULL                COMMENT 'Codigo de rastreamento',
  valor_subtotal  DECIMAL(10,2)                            NOT NULL                COMMENT 'Soma dos itens sem frete',
  valor_frete     DECIMAL(10,2)                            NOT NULL DEFAULT 8.90   COMMENT 'Taxa de entrega',
  valor_total     DECIMAL(10,2)                            NOT NULL                COMMENT 'Subtotal + frete',
  status          ENUM('processando','enviado','entregue') NOT NULL DEFAULT 'processando',
  dt_pedido       DATETIME                                 NOT NULL DEFAULT NOW(),
  PRIMARY KEY (id_pedido),
  UNIQUE KEY uk_pedido_rastreio (codigo_rastreio),
  CONSTRAINT fk_pedido_usuario FOREIGN KEY (id_usuario) REFERENCES Usuario (id_usuario)
) COMMENT = 'Pedidos realizados pelos clientes';

CREATE TABLE Item_Pedido (
  id_item                   INT           NOT NULL AUTO_INCREMENT,
  id_pedido                 INT           NOT NULL,
  id_produto                INT           NOT NULL,
  quantidade                INT           NOT NULL,
  preco_unitario_registrado DECIMAL(10,2) NOT NULL,
  PRIMARY KEY (id_item),
  CONSTRAINT fk_item_pedido  FOREIGN KEY (id_pedido)  REFERENCES Pedido  (id_pedido),
  CONSTRAINT fk_item_produto FOREIGN KEY (id_produto) REFERENCES Produto (id_produto)
) COMMENT = 'Itens que compoem cada pedido';

CREATE TABLE Pagamento (
  id_pagamento INT           NOT NULL AUTO_INCREMENT  COMMENT 'Identificador unico do pagamento',
  id_pedido    INT           NOT NULL                 COMMENT 'FK - pedido associado',
  metodo       ENUM('pix','cartao_credito','cartao_debito','boleto') NOT NULL COMMENT 'Metodo de pagamento',
  status       ENUM('pendente','aprovado','recusado','estornado')    NOT NULL DEFAULT 'pendente' COMMENT 'Status do pagamento',
  valor_pago   DECIMAL(10,2) NOT NULL                 COMMENT 'Valor pago (igual ao valor_total do pedido)',
  PRIMARY KEY (id_pagamento),
  UNIQUE KEY uk_pagamento_pedido (id_pedido),
  CONSTRAINT fk_pagamento_pedido FOREIGN KEY (id_pedido) REFERENCES Pedido (id_pedido)
) COMMENT = 'Registros de pagamento dos pedidos';

